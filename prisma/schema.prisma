generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  patches   Patch[]
  fixtures  Fixture[]
}

model Fixture {
  id               String        @id @default(cuid())
  manufacturer     String
  name             String
  weight           Float
  powerConsumption Float
  symbolUrl        String?
  isGlobal         Boolean       @default(false)
  createdBy        User?         @relation(fields: [createdById], references: [id])
  createdById      String?
  modes            FixtureMode[]
  patchGroups      PatchGroup[]
}

model FixtureMode {
  id           String       @id @default(cuid())
  name         String
  channelCount Int
  fixture      Fixture      @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  fixtureId    String
  patchGroups  PatchGroup[]
}

model Patch {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  designerName    String
  designerEmail   String?
  designerPhone   String?
  designerCompany String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User?        @relation(fields: [userId], references: [id])
  userId          String?
  groups          PatchGroup[]
}

model PatchGroup {
  id              String      @id @default(cuid())
  position        String
  universe        String
  startingId      Int
  startingAddress Int
  amount          Int
  order           Int         @default(0)
  patch           Patch       @relation(fields: [patchId], references: [id], onDelete: Cascade)
  patchId         String
  fixture         Fixture     @relation(fields: [fixtureId], references: [id])
  fixtureId       String
  mode            FixtureMode @relation(fields: [modeId], references: [id])
  modeId          String
}
